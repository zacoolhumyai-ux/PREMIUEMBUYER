local customToolName = ""

local function searchAndCloneTool(targetName)
    if targetName == "" then
        Rayfield:Notify({ Title = "Tools", Content = "ใส่ชื่อ Tool ก่อน!", Duration = 2 })
        return
    end

    local found = nil

    -- ค้นหาใน Backpack ของ Players คนอื่นก่อน
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player then
            local bp = plr:FindFirstChild("Backpack")
            if bp then
                local t = bp:FindFirstChild(targetName)
                if t and t:IsA("Tool") then found = t break end
            end
            if plr.Character then
                local t = plr.Character:FindFirstChild(targetName)
                if t and t:IsA("Tool") then found = t break end
            end
        end
    end

    -- ถ้าไม่เจอ ค้นหาใน workspace ทั้งหมด
    if not found then
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("Tool") and obj.Name == targetName then
                found = obj
                break
            end
        end
    end

    -- ถ้าไม่เจอ ค้นหาใน ReplicatedStorage / ServerStorage
    if not found then
        pcall(function()
            local RS = game:GetService("ReplicatedStorage")
            for _, obj in pairs(RS:GetDescendants()) do
                if obj:IsA("Tool") and obj.Name == targetName then
                    found = obj break
                end
            end
        end)
    end

    if found then
        local clone = found:Clone()
        clone.Parent = player.Backpack
        Rayfield:Notify({ Title = "Tools", Content = "เพิ่ม [" .. targetName .. "] เข้า Inventory!", Duration = 3 })
    else
        Rayfield:Notify({ Title = "Tools", Content = "ไม่พบ Tool: " .. targetName, Duration = 3 })
    end
end

local function listAllTools()
    local found = {}
    local seen = {}

    -- จาก Players อื่น
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player then
            local bp = plr:FindFirstChild("Backpack")
            if bp then
                for _, t in pairs(bp:GetChildren()) do
                    if t:IsA("Tool") and not seen[t.Name] then
                        seen[t.Name] = true
                        table.insert(found, t.Name)
                    end
                end
            end
            if plr.Character then
                for _, t in pairs(plr.Character:GetChildren()) do
                    if t:IsA("Tool") and not seen[t.Name] then
                        seen[t.Name] = true
                        table.insert(found, t.Name)
                    end
                end
            end
        end
    end

    -- จาก workspace
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Tool") and not seen[obj.Name] then
            seen[obj.Name] = true
            table.insert(found, obj.Name)
        end
    end

    -- จาก ReplicatedStorage
    pcall(function()
        local RS = game:GetService("ReplicatedStorage")
        for _, obj in pairs(RS:GetDescendants()) do
            if obj:IsA("Tool") and not seen[obj.Name] then
                seen[obj.Name] = true
                table.insert(found, obj.Name)
            end
        end
    end)

    table.sort(found)
    if #found == 0 then
        Rayfield:Notify({ Title = "Tools", Content = "ไม่พบ Tool ใดเลย", Duration = 3 })
    else
        -- แสดงทีละ 5 ชื่อ
        local msg = table.concat(found, ", ", 1, math.min(10, #found))
        if #found > 10 then msg = msg .. " ... (" .. #found .. " total)" end
        Rayfield:Notify({ Title = "พบ " .. #found .. " Tools", Content = msg, Duration = 6 })
        print("[NERD HUB] All Tools Found:")
        for _, name in pairs(found) do print(" -", name) end
    end
end

local function removeToolFromInventory(targetName)
    if targetName == "" then
        Rayfield:Notify({ Title = "Tools", Content = "ใส่ชื่อ Tool ก่อน!", Duration = 2 }) return
    end
    local backpack = player:FindFirstChild("Backpack")
    local removed = false
    if backpack then
        local t = backpack:FindFirstChild(targetName)
        if t then t:Destroy() removed = true end
    end
    if character then
        local t = character:FindFirstChild(targetName)
        if t and t:IsA("Tool") then t:Destroy() removed = true end
    end
    if removed then
        Rayfield:Notify({ Title = "Tools", Content = "ลบ [" .. targetName .. "] ออกแล้ว", Duration = 2 })
    else
        Rayfield:Notify({ Title = "Tools", Content = "ไม่พบ [" .. targetName .. "] ใน Inventory", Duration = 2 })
    end
end

