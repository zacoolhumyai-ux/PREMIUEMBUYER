local function autoAcceptQuest()
    local ok, err = pcall(function()
        local NPC = workspace.Merchants:FindFirstChild("QuestFishMerchant")
        if not NPC then error("NPC not found") end
        local hrp = NPC:FindFirstChild("HumanoidRootPart")
        if hrp and rootPart then rootPart.CFrame = hrp.CFrame task.wait(0.3) end
        local cd = getCooldown()
        if cd and cd > 0 then Rayfield:Notify({ Title = "Quest", Content = "Cooldown: " .. cd .. "s remaining", Duration = 3 }) return end
        local Retum = NPC.Clickable:FindFirstChild("Retum")
        if not Retum then error("Retum not found") end
        Retum:FireServer("Package")
        task.wait(0.1)
        Retum:FireServer("Close")
        Rayfield:Notify({ Title = "Quest", Content = "Quest accepted!", Duration = 2 })
        task.wait(1)
        tpAllMerchantsWithPackage()
    end)
    if not ok then Rayfield:Notify({ Title = "Quest Error", Content = tostring(err), Duration = 3 }) end
end

