-- =========================
-- BRING MOB SYSTEM (optimized - no lag)
-- =========================

local bringMobEnabled = false
local BRING_DISTANCE = 8
local BRING_OFFSET = 3
local BRING_INTERVAL = 0.2
local selectedMobs = {}

-- Cache mob instances ไว้ refresh ทุก 3 วิ แทนที่จะ scan ทุกรอบ
local mobCache = {}
local mobCacheElapsed = 0
local MOB_CACHE_TTL = 3

local function isMobSelected(mobName)
    if #selectedMobs == 0 then return true end
    for _, name in ipairs(selectedMobs) do
        if name == mobName then return true end
    end
    return false
end

local function getMobList()
    local char = player.Character
    local names = {}
    local seen = {}
    local playerChars = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr.Character then playerChars[plr.Character] = true end
    end
    pcall(function()
        for _, folder in pairs(workspace.Enemies:GetChildren()) do
            local function scanModel(model)
                if model:IsA("Model") and not playerChars[model] and model ~= char then
                    local hrp = model:FindFirstChild("HumanoidRootPart")
                    local hum = model:FindFirstChildOfClass("Humanoid")
                    if hrp and hum and hum.Health > 0 and not seen[model.Name] then
                        seen[model.Name] = true
                        table.insert(names, model.Name)
                    end
                end
            end
            scanModel(folder)
            for _, mob in pairs(folder:GetChildren()) do
                if mob:IsA("Model") then scanModel(mob) end
            end
        end
    end)
    if #names == 0 then
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("Model") and obj ~= char and not playerChars[obj] then
                local hrp = obj:FindFirstChild("HumanoidRootPart")
                local hum = obj:FindFirstChildOfClass("Humanoid")
                if hrp and hum and hum.Health > 0 and not seen[obj.Name] then
                    seen[obj.Name] = true
                    table.insert(names, obj.Name)
                end
            end
        end
    end
    table.sort(names)
    return names
end

local function refreshMobCache()
    mobCache = {}
    local char = player.Character
    if not char then return end
    local playerChars = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr.Character then playerChars[plr.Character] = true end
    end
    pcall(function()
        for _, folder in pairs(workspace.Enemies:GetChildren()) do
            local function tryCache(model)
                if model:IsA("Model") and model ~= char and not playerChars[model] then
                    local hrp = model:FindFirstChild("HumanoidRootPart")
                    local hum = model:FindFirstChildOfClass("Humanoid")
                    if hrp and hum and hum.Health > 0 and isMobSelected(model.Name) then
                        table.insert(mobCache, model)
                    end
                end
            end
            tryCache(folder)
            for _, mob in pairs(folder:GetChildren()) do
                if mob:IsA("Model") then tryCache(mob) end
            end
        end
    end)
end

local function bringMobs()
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local cf = hrp.CFrame

    -- refresh cache ทุก 3 วิ
    mobCacheElapsed += BRING_INTERVAL
    if mobCacheElapsed >= MOB_CACHE_TTL or #mobCache == 0 then
        refreshMobCache()
        mobCacheElapsed = 0
    end

    local index = 0
    for _, mob in ipairs(mobCache) do
        if mob and mob.Parent then
            local mobHRP = mob:FindFirstChild("HumanoidRootPart")
            local hum = mob:FindFirstChildOfClass("Humanoid")
            if mobHRP and hum and hum.Health > 0 then
                local offsetX = (index % 2 == 0 and 1 or -1) * (math.floor(index / 2) * BRING_OFFSET)
                pcall(function()
                    mob:PivotTo(cf + cf.LookVector * BRING_DISTANCE + cf.RightVector * offsetX)
                end)
                index += 1
                if index % 10 == 0 then task.wait() end
            end
        end
    end
end

