-- ONE HIT KILL SYSTEM (optimized)
-- =========================

local oneHitEnabled = false
local ONE_HIT_RANGE = 50
local ONE_HIT_RANGE_SQ = ONE_HIT_RANGE * ONE_HIT_RANGE

local playerCharsCache = {}
local cacheTimer = 0

local function updatePlayerCache()
    playerCharsCache = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr.Character then playerCharsCache[plr.Character] = true end
    end
end

local function oneHitAllNearby()
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    cacheTimer += 1
    if cacheTimer >= 30 then
        updatePlayerCache()
        cacheTimer = 0
    end

    local myPos = hrp.Position

    local function tryKill(model)
        if model == char or playerCharsCache[model] then return end
        local mobHRP = model:FindFirstChild("HumanoidRootPart")
        if not mobHRP then return end
        local diff = myPos - mobHRP.Position
        if (diff.X*diff.X + diff.Y*diff.Y + diff.Z*diff.Z) > ONE_HIT_RANGE_SQ then return end
        local hum = model:FindFirstChildOfClass("Humanoid")
        if hum and hum.Health > 0 then
            pcall(function() hum.Health = 0 end)
        end
    end

    local ok = pcall(function()
        for _, folder in pairs(workspace.Enemies:GetChildren()) do
            if folder:IsA("Model") then tryKill(folder) end
            for _, mob in pairs(folder:GetChildren()) do
                if mob:IsA("Model") then tryKill(mob) end
            end
        end
    end)

    if not ok then
        for _, obj in pairs(workspace:GetChildren()) do
            if obj:IsA("Model") then tryKill(obj) end
        end
    end
end

