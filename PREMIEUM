-- =========================
-- BRING MOB SYSTEM
-- =========================

local bringMobEnabled = false
local BRING_DISTANCE = 8
local BRING_OFFSET = 3
local BRING_INTERVAL = 0.1
local selectedMobs = {}

local function isMobSelected(mobName)
    if #selectedMobs == 0 then return true end
    for _, name in ipairs(selectedMobs) do
        if name == mobName then return true end
    end
    return false
end

local function getMobList()
    local char = game.Players.LocalPlayer.Character
    local names = {}
    local seen = {}
    local playerChars = {}
    for _, plr in ipairs(game.Players:GetPlayers()) do
        if plr.Character then playerChars[plr.Character] = true end
    end
    -- สแกนจาก workspace.Enemies ก่อน (ถ้ามี)
    pcall(function()
        for _, folder in pairs(workspace.Enemies:GetChildren()) do
            local function scanModel(model)
                if model:IsA("Model") and not playerChars[model] and model ~= char then
                    local hrp = model:FindFirstChild("HumanoidRootPart")
                    local hum = model:FindFirstChildOfClass("Humanoid")
                    if hrp and hum and hum.Health > 0 and not seen[model.Name] then
                        seen[model.Name] = true
                        table.insert(names, model.Name)
                    end
                end
            end
            scanModel(folder)
            for _, mob in pairs(folder:GetDescendants()) do
                if mob:IsA("Model") then scanModel(mob) end
            end
        end
    end)
    -- fallback: สแกน workspace ทั้งหมด
    if #names == 0 then
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("Model") and obj ~= char and not playerChars[obj] then
                local hrp = obj:FindFirstChild("HumanoidRootPart")
                local hum = obj:FindFirstChildOfClass("Humanoid")
                if hrp and hum and hum.Health > 0 and not seen[obj.Name] then
                    seen[obj.Name] = true
                    table.insert(names, obj.Name)
                end
            end
        end
    end
    table.sort(names)
    return names
end

local function bringMobs()
    local char = game.Players.LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local cf = hrp.CFrame
    local index = 0
    local playerChars = {}
    for _, plr in ipairs(game.Players:GetPlayers()) do
        if plr.Character then playerChars[plr.Character] = true end
    end

    -- ลอง workspace.Enemies ก่อน
    local function tryBring(obj)
        if obj:IsA("Model") and obj ~= char and not playerChars[obj] then
            local mobHRP = obj:FindFirstChild("HumanoidRootPart")
            local hum = obj:FindFirstChildOfClass("Humanoid")
            if mobHRP and hum and hum.Health > 0 and isMobSelected(obj.Name) then
                local offsetX = (index % 2 == 0 and 1 or -1) * (math.floor(index / 2) * BRING_OFFSET)
                pcall(function()
                    obj:PivotTo(cf + cf.LookVector * BRING_DISTANCE + cf.RightVector * offsetX)
                end)
                index += 1
                if index % 5 == 0 then task.wait() end
            end
        end
    end

    local usedEnemies = false
    pcall(function()
        for _, folder in pairs(workspace.Enemies:GetChildren()) do
            tryBring(folder)
            for _, mob in pairs(folder:GetDescendants()) do tryBring(mob) end
        end
        usedEnemies = true
    end)

    if not usedEnemies or index == 0 then
        for _, obj in ipairs(workspace:GetDescendants()) do tryBring(obj) end
    end
end

