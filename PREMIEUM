local autoCook = false
local fishToolNames = {"Small", "Medium", "Large"}

local function isFishTool(name)
    if string.find(name, "Cooked") then return false end
    for _, keyword in pairs(fishToolNames) do
        if string.find(name, keyword) then return true end
    end
    return false
end

local function getAllFishFromBackpack()
    local tools = {}
    for _, tool in pairs(player.Backpack:GetChildren()) do
        if tool:IsA("Tool") and isFishTool(tool.Name) then
            table.insert(tools, tool.Name)
        end
    end
    return tools
end

local function cookAllFishInInventory()
    local fishObj = workspace:GetChildren()[37]
    if not fishObj then Rayfield:Notify({ Title = "Auto Cook", Content = "Cook object not found", Duration = 2 }) return end
    local targetPart = fishObj:FindFirstChildWhichIsA("BasePart")
    if targetPart and rootPart then
        rootPart.CFrame = CFrame.new(targetPart.Position + Vector3.new(2, 0, 0))
        task.wait(0.5)
    end
    local toolNames = getAllFishFromBackpack()
    if #toolNames == 0 then Rayfield:Notify({ Title = "Auto Cook", Content = "No raw fish in backpack", Duration = 2 }) return end
    Rayfield:Notify({ Title = "Auto Cook", Content = "Found " .. #toolNames .. " fish, cooking...", Duration = 2 })
    local cooked = 0
    local humanoid = character and character:FindFirstChildWhichIsA("Humanoid")
    if not humanoid then return end
    for _, toolName in pairs(toolNames) do
        local tool = player.Backpack:FindFirstChild(toolName)
        if not tool then continue end
        humanoid:UnequipTools() task.wait(0.2)
        humanoid:EquipTool(tool) task.wait(0.5)
        pcall(function() mouse1click() end) task.wait(0.1)
        for _, desc in pairs(fishObj:GetDescendants()) do
            if desc:IsA("ClickDetector") then
                pcall(function() desc.MaxActivationDistance = 50 fireclickdetector(desc) end)
                task.wait(0.1) break
            end
        end
        cooked += 1
        Rayfield:Notify({ Title = "Auto Cook", Content = toolName .. " cooked! (" .. cooked .. "/" .. #toolNames .. ")", Duration = 1 })
        task.wait(0.5)
    end
    humanoid:UnequipTools()
    Rayfield:Notify({ Title = "Auto Cook", Content = "Done! Cooked " .. cooked .. " fish", Duration = 3 })
end

local function startAutoCook()
    task.spawn(function()
        while autoCook do
            pcall(cookAllFishInInventory)
            task.wait(2)
            if #getAllFishFromBackpack() == 0 then
                autoCook = false
                Rayfield:Notify({ Title = "Auto Cook", Content = "All fish cooked, stopped", Duration = 3 })
            end
        end
    end)
end

