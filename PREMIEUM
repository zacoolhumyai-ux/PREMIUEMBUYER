local function bringAndClickAllMerchants()
    Rayfield:Notify({ Title = "Quest", Content = "Bringing all Merchants...", Duration = 2 })
    local waited = 0
    while waited < 5 do
        if equipPackage() then break end
        task.wait(0.5)
        waited += 0.5
    end
    for i, name in ipairs(QuestMerchantList) do
        local NPC = workspace.Merchants:FindFirstChild(name)
        if not NPC or not rootPart or not character then continue end
        local follow
        follow = RunService.Heartbeat:Connect(function()
            if NPC and NPC.Parent and character then
                pcall(function()
                    local hrp = character:FindFirstChild("HumanoidRootPart")
                    if hrp then NPC:PivotTo(hrp.CFrame * CFrame.new(0, 0, -4)) end
                end)
            else
                if follow then follow:Disconnect() end
            end
        end)
        task.wait(0.2)
        equipPackage()
        for _, obj in pairs(NPC:GetDescendants()) do
            if obj:IsA("ClickDetector") then
                obj.MaxActivationDistance = 999
                pcall(function() fireclickdetector(obj) end)
                break
            end
        end
        Rayfield:Notify({ Title = i .. "/" .. #QuestMerchantList, Content = name, Duration = 0.5 })
        task.wait(0.8)
        if follow then follow:Disconnect() end
    end
    Rayfield:Notify({ Title = "Quest", Content = "All Merchants visited!", Duration = 3 })
end

