-- AUTO FISH SYSTEM
-- =========================

local autoFish = false
local fishConnection = nil
local effectLoop = nil

local function getRod()
    local char = player.Character
    if not char then return nil end
    for _, tool in pairs(char:GetChildren()) do
        if tool:IsA("Tool") and string.find(tool.Name, "Rod") then return tool end
    end
    for _, tool in pairs(player.Backpack:GetChildren()) do
        if tool:IsA("Tool") and string.find(tool.Name, "Rod") then return tool end
    end
    return nil
end

local function castRod(t)
    if t:FindFirstChild("Click") then
        t.Click:FireServer(player:GetMouse().Hit.p)
    end
end

local function stopEffectLoop()
    if effectLoop then effectLoop = false end
end

local function startAutoFish()
    task.spawn(function()
        while autoFish do
            local rod = getRod()
            if not rod then task.wait(0.5) continue end

            if player.Backpack:FindFirstChild(rod.Name) then
                local humanoid = character and character:FindFirstChildWhichIsA("Humanoid")
                if humanoid then humanoid:EquipTool(rod) task.wait(1) end
            end

            rod = player.Character and player.Character:FindFirstChild(rod.Name)
            if not rod then task.wait(0.5) continue end

            repeat task.wait(0.05) until rod:FindFirstChild("Click")
            repeat task.wait(0.05) until rod:FindFirstChild("Caught")

            castRod(rod)
            Rayfield:Notify({ Title = "Auto Fish", Content = "Line cast!", Duration = 1 })

            local timeout = 0
            repeat
                task.wait(0.1)
                timeout += 0.1
                if not autoFish then break end
                local cast = rod:FindFirstChild("Cast")
                if cast then
                    local bobber = cast:FindFirstChild("Bobber")
                    if bobber then
                        local effect = bobber:FindFirstChild("Effect")
                        if effect and effect.Enabled == true then
                            mouse1click()
                            Rayfield:Notify({ Title = "Auto Fish", Content = "Fish caught!", Duration = 1 })
                            task.wait(0.8)
                            break
                        end
                    end
                end
            until timeout > 30 or not autoFish

            task.wait(0.3)
        end

        stopEffectLoop()
        if fishConnection then fishConnection:Disconnect() fishConnection = nil end
    end)
end

