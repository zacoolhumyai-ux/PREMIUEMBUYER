-- =========================
-- AUTO PACKAGE SYSTEM
-- =========================

local autoPackage = false
local packageLoopRunning = false
local packageDelay = 1.5

local function getPackageTool()
    local backpack = player:FindFirstChild("Backpack")
    return (backpack and backpack:FindFirstChild("Package"))
        or (character and character:FindFirstChild("Package"))
end

local function getBitCFrame()
    local pkg = getPackageTool()
    if not pkg then return nil end
    local Bit = pkg:FindFirstChild("Bit")
    if not Bit then
        local PackageHandler = pkg:FindFirstChild("PackageHandler")
        if PackageHandler then Bit = PackageHandler:FindFirstChild("Bit") end
    end
    if not Bit then return nil end
    if Bit:IsA("BasePart") then return Bit.CFrame
    elseif Bit:IsA("Model") then
        if Bit.PrimaryPart then return Bit.PrimaryPart.CFrame end
        local bp = Bit:FindFirstChildWhichIsA("BasePart")
        if bp then return bp.CFrame end
    elseif Bit:IsA("CFrameValue") then return Bit.Value
    elseif Bit:IsA("Vector3Value") then return CFrame.new(Bit.Value) end
    return nil
end

local function doAutoPackage()
    local tool = getPackageTool()
    if not tool then Rayfield:Notify({ Title = "Auto Package", Content = "ไม่พบ Package ใน Backpack", Duration = 2 }) return false end
    local humanoid = character and character:FindFirstChildWhichIsA("Humanoid")
    if not humanoid then return false end
    if not character:FindFirstChild("Package") then humanoid:EquipTool(tool) task.wait(0.5) end
    local pkg = character:FindFirstChild("Package") or getPackageTool()
    if pkg then
        local PackageHandler = pkg:FindFirstChild("PackageHandler")
        if PackageHandler then
            if PackageHandler:IsA("RemoteEvent") then pcall(function() PackageHandler:FireServer() end)
            elseif PackageHandler:IsA("RemoteFunction") then pcall(function() PackageHandler:InvokeServer() end) end
        end
        for _, obj in pairs(pkg:GetDescendants()) do
            if obj:IsA("ClickDetector") then
                pcall(function() obj.MaxActivationDistance = 999 fireclickdetector(obj) end)
                break
            end
        end
    end
    Rayfield:Notify({ Title = "Auto Package", Content = "ได้ Package แล้ว รอ Bit...", Duration = 1 })
    task.wait(packageDelay)
    local bitCF = getBitCFrame()
    if bitCF then
        if rootPart then
            rootPart.CFrame = bitCF + Vector3.new(0, 3, 0)
            Rayfield:Notify({ Title = "Auto Package", Content = "TP ไปที่ Bit สำเร็จ!", Duration = 2 })
            return true
        end
    else
        Rayfield:Notify({ Title = "Auto Package", Content = "ไม่พบ CFrame ของ Bit", Duration = 2 })
    end
    return false
end

local function startAutoPackageLoop()
    if packageLoopRunning then return end
    packageLoopRunning = true
    task.spawn(function()
        while autoPackage do
            pcall(doAutoPackage)
            task.wait(packageDelay + 1)
            character = player.Character or player.CharacterAdded:Wait()
            rootPart = character:WaitForChild("HumanoidRootPart")
        end
        packageLoopRunning = false
    end)
end

