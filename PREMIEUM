local function autoAcceptSpecialQuest()
    local ok, err = pcall(function()
        local NPC = workspace.Merchants:FindFirstChild("QuestHakiMerchant")
        if not NPC then error("QuestHakiMerchant not found") end
        local hrp = NPC:FindFirstChild("HumanoidRootPart")
        if hrp and rootPart then
            rootPart.CFrame = hrp.CFrame + Vector3.new(3, 0, 0)
            task.wait(0.3)
        end
        local cd = getSpecialQuestCooldown()
        if cd and cd > 0 then
            Rayfield:Notify({ Title = "Special Quest", Content = "Cooldown: " .. cd .. "s remaining", Duration = 3 })
            return
        end
        local backpack = player:FindFirstChild("Backpack")
        local specialPkg = (backpack and backpack:FindFirstChild("Special Package"))
                        or (character and character:FindFirstChild("Special Package"))
        if not specialPkg then
            Rayfield:Notify({ Title = "Special Quest", Content = "Special Package not found", Duration = 3 })
            return
        end
        local humanoid = character and character:FindFirstChildWhichIsA("Humanoid")
        if humanoid then humanoid:EquipTool(specialPkg) task.wait(0.5) end
        local Clickable = NPC:FindFirstChild("Clickable")
        if not Clickable then error("Clickable not found") end
        local Retum = Clickable:FindFirstChild("Retum")
        if not Retum then error("Retum not found") end
        Retum:FireServer("Special Package")
        task.wait(0.1)
        Retum:FireServer("Close")
        Rayfield:Notify({ Title = "Special Quest", Content = "Special Quest accepted!", Duration = 2 })
        task.wait(1)
        tpAllMerchantsWithPackage()
    end)
    if not ok then Rayfield:Notify({ Title = "Special Quest Error", Content = tostring(err), Duration = 3 }) end
end

