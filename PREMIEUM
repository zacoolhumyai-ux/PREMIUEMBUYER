local autoSpawnDead = false

local function clickSpawnBtn()
    pcall(function()
        local LoadBtn = player.PlayerGui.Load.Frame.Load
        LoadBtn:Activate()
        pcall(function() LoadBtn.MouseButton1Click:Fire() end)
    end)
end

local function isSpawnScreenVisible()
    local ok, result = pcall(function()
        local LoadBtn = player.PlayerGui.Load.Frame.Load
        return LoadBtn and LoadBtn.Visible
    end)
    return ok and result
end

local function startAutoSpawnDead()
    task.spawn(function()
        while autoSpawnDead do
            task.wait(0.5)
            pcall(function()
                local char = player.Character
                local isDead = false

                -- เช็ค Humanoid health
                if not char then
                    isDead = true
                else
                    local humanoid = char:FindFirstChildOfClass("Humanoid")
                    if humanoid and humanoid.Health <= 0 then
                        isDead = true
                    end
                end

                -- เช็คจาก UpdateHaki.Nope (ถ้าตายจะมี flag)
                if not isDead then
                    pcall(function()
                        local userData = workspace.UserData:FindFirstChild("User_" .. player.UserId)
                        if userData then
                            local nope = userData.UpdateHaki:FindFirstChild("Nope")
                            if nope and nope.Disabled then
                                isDead = true
                            end
                        end
                    end)
                end

                if isDead then
                    -- กดซ้ำเรื่อยๆ จนกว่า spawn screen จะหาย
                    clickSpawnBtn()
                end
            end)
        end
    end)
end 

