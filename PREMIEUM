local VirtualInputManager = game:GetService("VirtualInputManager")
local autoHaki = false
local hakiHolding = false
local HOLD_KEY = Enum.KeyCode.R
local TOGGLE_HAKI_KEY = Enum.KeyCode.Q

local function KeyDown(key) VirtualInputManager:SendKeyEvent(true, key, false, game) end
local function KeyUp(key) VirtualInputManager:SendKeyEvent(false, key, false, game) end
local function PressKey(key) KeyDown(key) task.wait(0.05) KeyUp(key) end

local function GetHakiPercent()
    pcall(function() return workspace.UserData["User_" .. player.UserId].Data.Haki.Value end)
    return workspace.UserData["User_" .. player.UserId].Data.Haki.Value
end

task.spawn(function()
    while task.wait(0.2) do
        if autoHaki then
            local haki = GetHakiPercent()
            if haki <= 0 then
                if hakiHolding then hakiHolding = false KeyUp(HOLD_KEY) end
                Rayfield:Notify({ Title = "Auto Haki", Content = "Haki empty, waiting...", Duration = 2 })
                repeat task.wait(1) haki = GetHakiPercent() until haki >= 100 or not autoHaki
                if autoHaki then
                    PressKey(TOGGLE_HAKI_KEY) task.wait(0.5)
                    hakiHolding = true KeyDown(HOLD_KEY)
                    Rayfield:Notify({ Title = "Auto Haki", Content = "Haki full, resumed!", Duration = 2 })
                end
            else
                if not hakiHolding then hakiHolding = true KeyDown(HOLD_KEY) end
            end
        else
