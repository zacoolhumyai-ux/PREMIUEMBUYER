local function GetHakiPercent()
    local userData = workspace.UserData:FindFirstChild("User_" .. player.UserId)
    if not userData then return 100 end
    local hakiBar = userData:FindFirstChild("HakiBar")
    if not hakiBar then return 100 end
    local server = hakiBar:FindFirstChild("HakiBarServer")
    if not server then return 100 end
    return server.Value
end

local hopping = false

local function HopServer()
    if hopping then return end
    hopping = true
    pcall(function() writefile("nerd_autohaki.txt", "true") end)
    Rayfield:Notify({ Title = "Auto Haki", Content = "Haki 0% — Hopping Server...", Duration = 2 })
    task.wait(1.5)
    pcall(function() TeleportService:Teleport(game.PlaceId, player) end)
end

local function CheckAutoHakiResume()
    local ok, content = pcall(function() return readfile("nerd_autohaki.txt") end)
    if ok and content == "true" then
        pcall(function() writefile("nerd_autohaki.txt", "true") end)

        Rayfield:Notify({ Title = "Auto Haki", Content = "Clicking Spawn...", Duration = 2 })

        -- คลิก Load (Spawn) เรื่อยๆ จนกว่า character จะโหลด
        task.spawn(function()
            local clicked = false
            while not clicked do
                task.wait(0.5)
                pcall(function()
                    local playerGui = player:WaitForChild("PlayerGui")
                    local Load = playerGui:FindFirstChild("Load")
                    if Load then
                        local Frame = Load:FindFirstChild("Frame")
                        if Frame then
                            local LoadBtn = Frame:FindFirstChild("Load")
                            if LoadBtn then
                                LoadBtn:Activate()
                                pcall(function() LoadBtn.MouseButton1Click:Fire() end)
                            end
                        end
                    end
                end)
                -- หยุดกดเมื่อ character โหลดแล้ว
                if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                    clicked = true
                    Rayfield:Notify({ Title = "Auto Haki", Content = "Spawned!", Duration = 2 })
                end
            end
        end)

        task.wait(5)
        autoHaki = true
        PressKey(TOGGLE_HAKI_KEY)
        task.wait(0.5)
        hakiHolding = true
        KeyDown(HOLD_KEY)
        Rayfield:Notify({ Title = "Auto Haki", Content = "Auto resumed after hop!", Duration = 3 })
    end
end

task.spawn(function()
    task.wait(3)
    CheckAutoHakiResume()
end)

task.spawn(function()
    while task.wait(0.2) do
        if autoHaki then
            local ok, haki = pcall(GetHakiPercent)
            if not ok then haki = 100 end
            if haki <= 0 then
                if hakiHolding then
                    hakiHolding = false
                    KeyUp(HOLD_KEY)
                end
                HopServer()
            else
                hopping = false
                if not hakiHolding then
                    hakiHolding = true
                    KeyDown(HOLD_KEY)
                end
            end
        else
            if hakiHolding then
                hakiHolding = false
                KeyUp(HOLD_KEY)
            end
        end
    end
end)
