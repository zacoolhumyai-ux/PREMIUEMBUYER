local KeyboardTab = Window:CreateTab("Auto Key", 4483362458)

local autoKeyEnabled = false
local selectedKeys = {}
local keyPressDelay = 0.2
local keyHoldDuration = 0.05

local keyMap = {
    ["Z"] = Enum.KeyCode.Z,
    ["X"] = Enum.KeyCode.X,
    ["C"] = Enum.KeyCode.C,
    ["V"] = Enum.KeyCode.V,
    ["B"] = Enum.KeyCode.B,
    ["N"] = Enum.KeyCode.N,
    ["F"] = Enum.KeyCode.F,
    ["G"] = Enum.KeyCode.G,
    ["H"] = Enum.KeyCode.H,
    ["J"] = Enum.KeyCode.J,
    ["K"] = Enum.KeyCode.K,
    ["L"] = Enum.KeyCode.L,
}

local function pressSelectedKeys()
    for _, keyName in ipairs(selectedKeys) do
        local keyCode = keyMap[keyName]
        if keyCode then
            VirtualInputManager:SendKeyEvent(true, keyCode, false, game)
            task.wait(keyHoldDuration)
            VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
            task.wait(keyPressDelay)
        end
    end
end

local function startAutoKeyboard()
    task.spawn(function()
        while autoKeyEnabled do
            if #selectedKeys > 0 then
                pcall(pressSelectedKeys)
            end
            task.wait(0.05)
        end
    end)
end

